APP_NAME=MedReg Copilot
APP_ENV=development
APP_CORS_ORIGINS=["http://localhost:5273","http://127.0.0.1:5273"]
APP_ALLOWED_HOSTS=["*"]
API_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://medreg:medreg@127.0.0.1:55432/medreg
REDIS_URL=redis://localhost:6479/0
QDRANT_URL=http://127.0.0.1:6433
QDRANT_COLLECTION=medreg_legal_chunks_v1
QDRANT_API_KEY=
EMBEDDING_DENSE_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_SPARSE_MODEL=Qdrant/bm25
EMBEDDING_CACHE_DIR=~/.cache/medreg-fastembed
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=medreg-secret
MINIO_ENDPOINT=localhost:9100
MINIO_ACCESS_KEY=medreg
MINIO_SECRET_KEY=medreg-secret
MINIO_BUCKET=medreg-documents
MINIO_SECURE=false
DOCUMENT_MAX_UPLOAD_BYTES=20971520
DOCUMENT_PARSE_STALE_AFTER_SECONDS=300
OFFICIAL_FETCH_TIMEOUT_SECONDS=20
OFFICIAL_FETCH_ALLOWED_HOSTS=["samr.gov.cn","nmpa.gov.cn"]

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=45
